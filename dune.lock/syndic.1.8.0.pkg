(version 1.8.0)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs}))))))

(depends
 (all_platforms
  (ocaml dune ptime uri xmlm)))

(source
 (fetch
  (url
   https://github.com/Cumulus/Syndic/releases/download/v1.8.0/syndic-1.8.0.tbz)
  (checksum
   sha512=78e8544916b11cdb6b6f5b6692d7c4bf6500e2a727c41b02dd4580cfe95dad949d8273d703ec4827b3480111b248a61a551b041b0ae9fa15feece7f9b9fd7dcd)))
