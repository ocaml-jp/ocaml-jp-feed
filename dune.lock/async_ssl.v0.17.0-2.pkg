(version v0.17.0-2)

(build
 (all_platforms
  ((action
    (progn
     (patch no-warnings-017-2.patch)
     (run dune build -p %{pkg-self:name} -j %{jobs}))))))

(depends
 (all_platforms
  (ocaml
   async
   base
   core
   ppx_jane
   ppx_optcomp
   stdio
   conf-libssl
   ctypes
   ctypes-foreign
   dune
   dune-configurator)))

(source
 (fetch
  (url
   https://github.com/janestreet/async_ssl/archive/refs/tags/v0.17.0.tar.gz)
  (checksum
   sha256=d1f9ca883ce9154571b2812235171707b70cb8e65b24ed3aeaec1fbebc5be1ba)))

(extra_sources
 (no-warnings-017-2.patch
  (fetch
   (url
    https://raw.githubusercontent.com/ocaml/opam-source-archives/main/patches/async_ssl/no-warnings-017-2.patch)
   (checksum
    sha256=074a08e80f67bc3c6749fef91fb79825f2c7bfca270f079b47e734be45af2a53))))
